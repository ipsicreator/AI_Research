# Copy to `.streamlit/secrets.toml` and set values.

# Preferred mode: Google Apps Script Web App
APPS_SCRIPT_WEB_APP_URL = "https://script.google.com/macros/s/xxxxxxxx/exec"
APPS_SCRIPT_TOKEN = "optional"

# OpenAI enhancement (optional)
OPENAI_API_KEY = "sk-..."
OPENAI_MODEL = "gpt-4o-mini"

# Legacy mode: Service Account (optional fallback)
GOOGLE_SERVICE_ACCOUNT_FILE = "C:\\path\\to\\service_account.json"
GOOGLE_SHEETS_ID = "your_google_sheet_id"
